# Firebase native Android push
FIREBASE_PROJECT_ID=
FIREBASE_CLIENT_EMAIL=
FIREBASE_PRIVATE_KEY=
# Or point to a JSON service account file:
# FIREBASE_SERVICE_ACCOUNT_PATH=server/firebase-service-account.json
